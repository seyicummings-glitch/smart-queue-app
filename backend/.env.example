SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=sqlite:///db.sqlite3

# ── Email ──────────────────────────────────────────────────────────────────────
# By default Django prints OTP emails to the terminal (console backend).
# To send real emails, uncomment the lines below and fill in your credentials.
#
# Gmail example (create an App Password at myaccount.google.com/apppasswords):
#
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-address@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=SQMS <your-address@gmail.com>
